{
  "manifest_version": 3,
  "name": "탭talk · 집중 집사",
  "version": "0.1.0",
  "description": "딴짓 탭으로 새는 순간 정중한 집사가 집중을 되찾아 주는 크롬 확장.",
  "default_locale": "ko",
  "permissions": ["tabs", "storage", "notifications", "alarms", "sidePanel"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://tabtalk-jinpro0318-162012.azurewebsites.net/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "탭talk",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "side_panel": {
    "default_path": "warn/warn.html"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/content.js"],
      "css": ["css/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "https://tabtalk-jinpro0318-162012.azurewebsites.net/*"
      ],
      "js": ["content/bridge.js"],
      "run_at": "document_start"
    }
  ]
}
