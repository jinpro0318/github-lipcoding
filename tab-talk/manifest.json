{
  "manifest_version": 3,
  "name": "Tab Talk",
  "version": "0.1.0",
  "description": "딴짓 탭 이동과 눈맞춤 변화를 감지해, 4명의 집사가 여러분의 집중 시간을 함께 관리해드립니다.",
  "default_locale": "ko",
  "permissions": ["tabs", "storage", "notifications", "alarms", "system.memory"],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://tabtalk-jinpro0318-162012.azurewebsites.net/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "탭talk",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.youtu.be/*",
        "*://*.netflix.com/*",
        "*://*.twitch.tv/*",
        "*://*.chzzk.naver.com/*",
        "*://*.tving.com/*",
        "*://*.wavve.com/*",
        "*://*.laftel.net/*",
        "*://*.disneyplus.com/*",
        "*://*.coupang.com/*",
        "*://*.11st.co.kr/*",
        "*://*.gmarket.co.kr/*",
        "*://*.aliexpress.com/*",
        "*://*.amazon.com/*",
        "*://*.musinsa.com/*",
        "*://*.shopping.naver.com/*",
        "*://*.ssg.com/*",
        "*://*.auction.co.kr/*",
        "*://*.29cm.co.kr/*",
        "*://*.ably.co.kr/*",
        "*://*.instagram.com/*",
        "*://*.facebook.com/*",
        "*://*.x.com/*",
        "*://*.twitter.com/*",
        "*://*.threads.net/*",
        "*://*.tiktok.com/*",
        "*://*.dcinside.com/*",
        "*://*.fmkorea.com/*",
        "*://*.ruliweb.com/*",
        "*://*.clien.net/*",
        "*://*.theqoo.net/*",
        "*://*.reddit.com/*",
        "*://*.inven.co.kr/*",
        "*://*.mlbpark.donga.com/*",
        "*://*.bobaedream.co.kr/*",
        "*://*.store.steampowered.com/*",
        "*://*.steamcommunity.com/*",
        "*://*.leagueoflegends.com/*",
        "*://*.op.gg/*",
        "*://*.game.naver.com/*",
        "*://*.epicgames.com/*",
        "*://*.entertain.naver.com/*",
        "*://*.sports.news.naver.com/*",
        "*://*.news.nate.com/*",
        "*://*.insight.co.kr/*",
        "*://*.wikitree.co.kr/*",
        "*://*.comic.naver.com/*",
        "*://*.webtoon.naver.com/*",
        "*://*.webtoon.kakao.com/*",
        "*://*.page.kakao.com/*",
        "*://*.bomtoon.com/*",
        "*://*.lezhin.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["css/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "https://tabtalk-jinpro0318-162012.azurewebsites.net/*"
      ],
      "js": ["content/bridge.js"],
      "run_at": "document_start"
    }
  ]
}
